#!/usr/bin/env python3
"""omd — Oh My Dotfiles TUI Package Manager"""

import curses
import os
import subprocess
import sys
from dataclasses import dataclass, field
from pathlib import Path

# --- Paths ---
OMD_HOME = Path(os.environ.get("USER_CONFIG_HOME", Path.home() / ".oh-my-dotfiles"))
CONF_DIR = OMD_HOME / "etc" / "omd"
CONF_FILE = CONF_DIR / "packages.conf"
ENV_FILE = CONF_DIR / "env.sh"
DEP_DIR = OMD_HOME / "dep"
BIN_DIR = OMD_HOME / "bin"


# --- Package Registry ---
@dataclass
class Package:
    id: str
    name: str
    desc: str
    tab: str
    category: str
    presets: list = field(default_factory=list)
    check_cmd: str = ""
    install_cmds: dict = field(default_factory=dict)  # {"linux": [...], "darwin": [...]}
    env_snippet: str = ""


PACKAGES = [
