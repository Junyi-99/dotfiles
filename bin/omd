TABS = ["Basics", "CLI Agents", "Skills", "Plugins"]


# --- Config I/O ---
def load_config() -> dict:
    """Load package selections from config file. Returns {id: bool}."""
    config = {}
    if CONF_FILE.exists():
        for line in CONF_FILE.read_text().splitlines():
            line = line.strip()
            if line and not line.startswith("#") and "=" in line:
                pkg_id, state = line.split("=", 1)
                config[pkg_id.strip()] = state.strip() == "enabled"
    return config


def save_config(selections: dict):
    """Save package selections to config file."""
    CONF_DIR.mkdir(parents=True, exist_ok=True)
    lines = ["# Generated by omd\n"]
    for pkg in PACKAGES:
        state = "enabled" if selections.get(pkg.id, False) else "disabled"
        lines.append(f"{pkg.id}={state}\n")
    CONF_FILE.write_text("".join(lines))


def generate_env(selections: dict):
    """Generate env.sh for enabled packages."""
    CONF_DIR.mkdir(parents=True, exist_ok=True)
    lines = ["# Generated by omd — do not edit\n"]
    for pkg in PACKAGES:
        if selections.get(pkg.id, False) and pkg.env_snippet:
            lines.append(pkg.env_snippet)
    ENV_FILE.write_text("".join(lines))


# --- Installer ---
def get_platform() -> str:
    import platform
    return "darwin" if platform.system() == "Darwin" else "linux"


def is_installed(pkg: Package) -> bool:
    if not pkg.check_cmd:
        return True
    return subprocess.run(pkg.check_cmd, shell=True, capture_output=True).returncode == 0


def install_package(pkg: Package, quiet: bool = False) -> bool:
    platform = get_platform()
    cmds = pkg.install_cmds.get(platform, pkg.install_cmds.get("all", []))
    if not cmds:
        if not quiet:
            print(f"  ⚠ {pkg.name}: no installer for {platform}, install manually")
        return False
    for cmd in cmds:
        if not quiet:
            print(f"  → {pkg.name}: {cmd}")
        result = subprocess.run(cmd, shell=True, capture_output=quiet)
        if result.returncode != 0:
            if not quiet:
                print(f"  ✗ {pkg.name}: install failed")
            return False
    return True


def cmd_install(quiet: bool = False):
    """Install enabled packages and generate env.sh."""
    selections = load_config()
    if not selections:
        if not quiet:
            print("No packages.conf found. Run 'omd' to select packages.")
        return

    newly_installed = 0
    for pkg in PACKAGES:
        if not selections.get(pkg.id, False):
            continue
        if is_installed(pkg):
            continue
        if not quiet:
            print(f"  Installing {pkg.name}...")
        if install_package(pkg, quiet):
            newly_installed += 1

    generate_env(selections)

    if not quiet and newly_installed > 0:
        print(f"\n  ✓ {newly_installed} package(s) newly installed")
    elif not quiet:
        print("  ✓ All selected packages are installed")


# --- TUI ---
class TUI:
    def __init__(self, stdscr):
        self.stdscr = stdscr
        self.current_tab = 0
        self.cursor = 0
        self.selections = load_config()
        # Default: if no config, enable minimal preset
        if not self.selections:
            self._apply_preset("minimal")

        self._build_tab_items()

        curses.curs_set(0)
        curses.start_color()
        curses.use_default_colors()
        curses.init_pair(1, curses.COLOR_GREEN, -1)   # enabled
        curses.init_pair(2, curses.COLOR_RED, -1)      # disabled
        curses.init_pair(3, curses.COLOR_CYAN, -1)     # active tab
        curses.init_pair(4, curses.COLOR_YELLOW, -1)   # preset key
        curses.init_pair(5, curses.COLOR_WHITE, curses.COLOR_BLUE)  # cursor
        curses.init_pair(6, curses.COLOR_WHITE, -1)    # dimmed

    def _build_tab_items(self):
        """Build ordered list of items (categories + packages) for each tab."""
        self.tab_items = {}
        for tab in TABS:
            items = []
            seen_cats = []
            tab_pkgs = [p for p in PACKAGES if p.tab == tab]
            for pkg in tab_pkgs:
                if pkg.category not in seen_cats:
                    seen_cats.append(pkg.category)
                    items.append(("category", pkg.category))
                items.append(("package", pkg))
            self.tab_items[tab] = items
        self.cursor = 0
        self._skip_to_package()

    def _skip_to_package(self):
        """Ensure cursor is on a package, not a category header."""
        items = self.tab_items.get(TABS[self.current_tab], [])
        if not items:
            return
        while self.cursor < len(items) and items[self.cursor][0] == "category":
            self.cursor += 1
        if self.cursor >= len(items):
            self.cursor = 0
            while self.cursor < len(items) and items[self.cursor][0] == "category":
                self.cursor += 1

    def _apply_preset(self, preset: str):
        for pkg in PACKAGES:
            self.selections[pkg.id] = preset in pkg.presets

    def _toggle_all(self):
        tab = TABS[self.current_tab]
        tab_pkgs = [p for p in PACKAGES if p.tab == tab]
        all_on = all(self.selections.get(p.id, False) for p in tab_pkgs)
        for p in tab_pkgs:
            self.selections[p.id] = not all_on

    def _count_enabled(self, tab: str) -> tuple:
        tab_pkgs = [p for p in PACKAGES if p.tab == tab]
        enabled = sum(1 for p in tab_pkgs if self.selections.get(p.id, False))
        return enabled, len(tab_pkgs)

    def draw(self):
        self.stdscr.erase()
        h, w = self.stdscr.getmaxyx()
        if h < 15 or w < 50:
            self.stdscr.addstr(0, 0, "Terminal too small (need 50x15)")
            self.stdscr.refresh()
            return

        row = 0

        # Title
        title = " omd — Oh My Dotfiles "
        self.stdscr.addstr(row, 0, title, curses.A_BOLD)
        row += 1
        self.stdscr.addstr(row, 0, "━" * min(w - 1, 60))
        row += 1

        # Tabs
        col = 0
        for i, tab in enumerate(TABS):
            en, total = self._count_enabled(tab)
            label = f" {i+1} {tab} ({en}/{total}) "
            if i == self.current_tab:
                self.stdscr.addstr(row, col, label, curses.color_pair(3) | curses.A_BOLD)
            else:
                self.stdscr.addstr(row, col, label, curses.color_pair(6))
            col += len(label) + 1
        row += 1
        self.stdscr.addstr(row, 0, "━" * min(w - 1, 60))
        row += 1

        # Presets
        self.stdscr.addstr(row, 0, "  Presets: ", curses.A_DIM)
        for key, name in [("m", "minimal"), ("g", "agent"), ("f", "full")]:
            self.stdscr.addstr(f" (", curses.A_DIM)
            self.stdscr.addstr(key, curses.color_pair(4) | curses.A_BOLD)
            self.stdscr.addstr(f"){name}", curses.A_DIM)
        row += 2

        # Items
        items = self.tab_items.get(TABS[self.current_tab], [])
        if not items:
            self.stdscr.addstr(row, 2, "(empty — coming soon)", curses.A_DIM)
            row += 1
        else:
            max_name_len = max((len(p.name) for _, p in items if _ == "package"), default=20)
            for i, (kind, val) in enumerate(items):
                if row >= h - 2:
                    break
                if kind == "category":
                    if i > 0:
                        row += 1
                    self.stdscr.addstr(row, 2, val, curses.A_BOLD | curses.A_UNDERLINE)
                    row += 1
                else:
                    pkg = val
                    checked = self.selections.get(pkg.id, False)
                    marker = "x" if checked else " "
                    color = curses.color_pair(1) if checked else curses.color_pair(2)
                    is_cursor = i == self.cursor

                    prefix = " ▸ " if is_cursor else "   "
                    checkbox = f"[{marker}]"
                    name_str = f" {pkg.name:<{max_name_len}}  "
                    desc_str = pkg.desc

                    attr = curses.color_pair(5) | curses.A_BOLD if is_cursor else 0

                    self.stdscr.addstr(row, 0, prefix, attr)
                    self.stdscr.addstr(checkbox, color | (curses.A_BOLD if is_cursor else 0))
                    self.stdscr.addstr(name_str, attr if is_cursor else curses.A_BOLD)
                    remaining = w - len(prefix) - len(checkbox) - len(name_str) - 1
                    if remaining > 0:
                        self.stdscr.addstr(desc_str[:remaining], curses.A_DIM)
                    row += 1

        # Footer
        footer_row = h - 1
        footer = " ↑↓/jk Navigate  Space Toggle  a All  Tab Next  Enter Install  q Quit "
        self.stdscr.addstr(footer_row, 0, footer[:w-1], curses.A_REVERSE)

        self.stdscr.refresh()

    def run(self) -> bool:
        """Run TUI. Returns True if user confirmed (Enter), False if quit (q)."""
        while True:
            self.draw()
            key = self.stdscr.getch()
            items = self.tab_items.get(TABS[self.current_tab], [])

            if key in (ord("q"), ord("Q"), 27):  # q or Escape
                return False

            elif key == ord("\n"):  # Enter
                return True

            elif key in (curses.KEY_UP, ord("k")):
                if items:
                    self.cursor -= 1
                    if self.cursor < 0:
                        self.cursor = len(items) - 1
                    while items[self.cursor][0] == "category":
                        self.cursor -= 1
                        if self.cursor < 0:
                            self.cursor = len(items) - 1

            elif key in (curses.KEY_DOWN, ord("j")):
                if items:
                    self.cursor += 1
                    if self.cursor >= len(items):
                        self.cursor = 0
                    while items[self.cursor][0] == "category":
                        self.cursor += 1
                        if self.cursor >= len(items):
                            self.cursor = 0

            elif key == ord(" "):  # Space: toggle
                if items and items[self.cursor][0] == "package":
                    pkg = items[self.cursor][1]
                    self.selections[pkg.id] = not self.selections.get(pkg.id, False)

            elif key == ord("a"):  # Toggle all in current tab
                self._toggle_all()

            elif key in (ord("\t"), curses.KEY_RIGHT, ord("l")):  # Tab / Right: next tab
                self.current_tab = (self.current_tab + 1) % len(TABS)
                self.cursor = 0
                self._skip_to_package()

            elif key in (curses.KEY_BTAB, curses.KEY_LEFT, ord("h")):  # Shift-Tab / Left: prev tab
                self.current_tab = (self.current_tab - 1) % len(TABS)
                self.cursor = 0
                self._skip_to_package()

            elif key == ord("m"):
                self._apply_preset("minimal")
            elif key == ord("g"):
                self._apply_preset("agent")
            elif key == ord("f"):
                self._apply_preset("full")

            elif key in (ord("1"), ord("2"), ord("3"), ord("4")):
                idx = key - ord("1")
                if idx < len(TABS):
                    self.current_tab = idx
                    self.cursor = 0
                    self._skip_to_package()


def tui_main(stdscr) -> bool:
    tui = TUI(stdscr)
    return tui.run()


def main():
    if len(sys.argv) > 1 and sys.argv[1] == "install":
        quiet = "--quiet" in sys.argv
        cmd_install(quiet)
        return

    selections = {}

    def run_tui(stdscr):
        nonlocal selections
        tui = TUI(stdscr)
        if tui.run():
            selections = dict(tui.selections)
            return True
        return False

    confirmed = curses.wrapper(run_tui)

    if confirmed and selections:
        save_config(selections)
        generate_env(selections)
        total = sum(1 for v in selections.values() if v)
        print(f"\n  ✓ Saved {total} package(s) to {CONF_FILE}")
        print(f"  Run 'omd install' to install, or restart your shell.\n")
    else:
        print("  Cancelled.\n")


if __name__ == "__main__":
    main()
