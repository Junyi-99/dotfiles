            env_snippet=f"""
# zsh-autosuggestions
source "{DEP_DIR}/zsh-autosuggestions/zsh-autosuggestions.zsh"
export ZSH_AUTOSUGGEST_STRATEGY=(match_prev_cmd completion)
ZSH_AUTOSUGGEST_CLEAR_WIDGETS+=(bracketed-paste)
bindkey '^B' autosuggest-toggle
"""),
    Package("zsh-syntax-highlighting", "zsh-syntax-highlighting", "Command highlighting",
